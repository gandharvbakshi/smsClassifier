<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom expanded view for OTP notifications. Adds the SMS body underneath the
  large OTP code. The Copy button itself is supplied by NotificationCompat.Action
  and is rendered by the system below this view (not in this layout).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="4dp"
    android:paddingEnd="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/notif_otp_sender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="?android:attr/textColorSecondary"
        android:singleLine="true"
        android:ellipsize="end"
        android:text="OTP from sender" />

    <TextView
        android:id="@+id/notif_otp_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="40sp"
        android:textStyle="bold"
        android:letterSpacing="0.18"
        android:textColor="?android:attr/textColorPrimary"
        android:text="000000"
        android:fontFamily="sans-serif-medium"
        android:singleLine="true" />

    <TextView
        android:id="@+id/notif_otp_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="13sp"
        android:textColor="?android:attr/textColorSecondary"
        android:maxLines="6"
        android:ellipsize="end"
        android:text="Message body" />
</LinearLayout>
