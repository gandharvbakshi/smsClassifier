<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="4dp"
    android:paddingEnd="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="10dp">

    <!--
      Use TextAppearance.Compat.Notification.* styles so text color adapts to
      whatever surface the system renders on (lock screen, shade, heads-up,
      Quick Settings pull-down). Plain `?android:attr/textColorPrimary` does
      NOT remap reliably on OEM ROMs (OnePlus/ColorOS, MIUI, One UI), causing
      dark-on-dark unreadable text in the QS pull-down.
    -->
    <TextView
        android:id="@+id/notif_otp_sender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Line2"
        android:textSize="12sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:text="OTP from sender" />

    <TextView
        android:id="@+id/notif_otp_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
        android:textSize="40sp"
        android:textStyle="bold"
        android:letterSpacing="0.18"
        android:text="000000"
        android:fontFamily="sans-serif-medium"
        android:singleLine="true" />

    <TextView
        android:id="@+id/notif_otp_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Line2"
        android:textSize="13sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:text="Message body" />

    <TextView
        android:id="@+id/notif_otp_warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Line2"
        android:textColor="@color/suspicious_amber"
        android:textStyle="bold"
        android:textSize="13sp"
        android:text="Never share this OTP with anyone."
        android:visibility="gone" />

    <Button
        android:id="@+id/notif_copy_otp_button"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_notif_copy_button"
        android:gravity="center"
        android:text="Copy OTP"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="bold" />
</LinearLayout>
