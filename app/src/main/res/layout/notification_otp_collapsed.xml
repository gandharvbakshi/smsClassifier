<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom collapsed view for OTP notifications. Shown in the lock screen, the
  notification shade (collapsed), and Heads-Up. The OTP code is the focal point
  so the user can read it at a glance without expanding.

  We use DecoratedCustomViewStyle on the builder, which means Android adds the
  app icon, app name, and time around this view automatically.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="4dp"
    android:paddingEnd="8dp"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!--
      Use TextAppearance.Compat.Notification.* styles so text color adapts to
      whatever surface the system renders on (lock screen, shade, heads-up,
      Quick Settings pull-down). Plain `?android:attr/textColorPrimary` does
      NOT remap reliably on OEM ROMs (OnePlus/ColorOS, MIUI, One UI), causing
      dark-on-dark unreadable text in the QS pull-down.
    -->
    <TextView
        android:id="@+id/notif_otp_sender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Line2"
        android:textSize="12sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:text="OTP from sender" />

    <TextView
        android:id="@+id/notif_otp_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.14"
        android:text="000000"
        android:fontFamily="sans-serif-medium"
        android:singleLine="true" />
</LinearLayout>
