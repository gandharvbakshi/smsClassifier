<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom collapsed view for OTP notifications. Shown in the lock screen, the
  notification shade (collapsed), and Heads-Up. The OTP code is the focal point
  so the user can read it at a glance without expanding.

  We use DecoratedCustomViewStyle on the builder, which means Android adds the
  app icon, app name, and time around this view automatically.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="4dp"
    android:paddingEnd="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="10dp">

    <TextView
        android:id="@+id/notif_otp_sender"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="?android:attr/textColorSecondary"
        android:singleLine="true"
        android:ellipsize="end"
        android:text="OTP from sender" />

    <TextView
        android:id="@+id/notif_otp_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textSize="34sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:textColor="?android:attr/textColorPrimary"
        android:text="000000"
        android:fontFamily="sans-serif-medium"
        android:singleLine="true" />
</LinearLayout>
