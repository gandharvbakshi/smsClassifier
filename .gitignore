# Keystore files - NEVER commit these!
keystore.properties
*.jks
*.keystore
release-keystore.jks
test-keystore.jks
upload-keystore.jks

# Google Play Developer API service-account credentials - NEVER commit!
play-publisher.json
**/play-publisher.json
# Key downloaded from Google Cloud (often PROJECT-ID-<suffix>.json)
app/smsclassifier-*.json

# Build files
build/
.gradle/
*.iml
.idea/

# Local configuration
local.properties

# Firebase Android config (contains project identifiers; keep local only)
app/google-services.json

# Secrets / API keys - NEVER commit these!
.env
*.env
!*.env.example

# Analysis artifacts contain real SMS bodies (PII): card numbers, balances,
# transaction amounts, OTPs. Only the *.py scripts and requirements.txt are
# safe to commit. EVERYTHING else under analysis/ is excluded by default.
analysis/*
!analysis/*.py
!analysis/requirements.txt
!analysis/.gitkeep

# Raw SMS classifier log dumped from the device — PII.
sms classifier log*.csv

# Gradle Play Publisher upload log (regenerated on every release, no value in git)
publish-release.log

# Local screenshot staging folder; curated Play assets live under app/src/main/play.
App screen shots*/

# Local human notes for monetization planning
monetization steps for humans.md

# Backend-generated artifacts and local model/runtime outputs.
# Keep backend source on main, but do not stage raw SMS corpora, checkpoints,
# generated model files, local feedback dumps, or deploy helper files with
# inlined credentials.
trained_models/
backend/trained_models/
backend/data/
backend/checkpoints/
backend/models/
backend/heuristic_test_results/
backend/model_comparison_results/
backend/synthetic_test_results/
backend/debug_output.txt
backend/debug_test.py
backend/analysis_results_v3.txt
backend/SMS_Datasaet_for_HF.png
backend_push_commands
*_push_commands
.tmp_feedback/
__pycache__/
**/__pycache__/
**/*.pyc

