# Template for the parent project .env file.
# COPY this to `.env` and fill in actual values. NEVER commit `.env` itself.
#
# All values shown are placeholders, not real keys.

# Groq (used by the Cloud Run backend for OTP intent classification via llama-3.x)
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY

# Google Generative AI (used by analysis/jury_judge.py for gemini-2.5-flash-lite)
GOOGLE_API_KEY=AIzaREPLACE_WITH_YOUR_GOOGLE_KEY

# OpenAI (used by analysis/jury_judge.py for gpt-4o-mini)
OPENAI_API_KEY=sk-proj-REPLACE_WITH_YOUR_OPENAI_KEY

# DeepSeek (used by analysis/jury_judge.py for deepseek-chat)
DEEPSEEK_API_KEY=sk-REPLACE_WITH_YOUR_DEEPSEEK_KEY

# Anthropic Claude (optional; not currently used by jury, but available for future)
# ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_WITH_YOUR_CLAUDE_KEY

# Optional: log raw SMS bodies in backend (default: false). Be careful with PII.
# LOG_RAW_MESSAGES=false

# Optional: classification thresholds (defaults: 0.5)
# OTP_THRESHOLD=0.5
# PHISH_THRESHOLD=0.5

# Optional: Groq model + timeout
# GROQ_INTENT_MODEL=llama-3.1-8b-instant
# GROQ_TIMEOUT=45

# Optional: Android Publisher API credentials for server-side purchase
# validation. Prefer Secret Manager in production. Use only one of these.
# ANDROID_PUBLISHER_CREDENTIALS_JSON={"type":"service_account",...}
# ANDROID_PUBLISHER_CREDENTIALS_FILE=android_sms_classifier/app/play-publisher.json
# PLAY_PACKAGE_NAME=com.smsclassifier.app

# Optional: protected backend admin API for entitlement lookup, gift Pro grants,
# and entitlement stats. Use a long random value and store it in Secret Manager
# for production Cloud Run deployments.
# ADMIN_API_TOKEN=replace_with_long_random_admin_token
# Local operator scripts may use SMS_ADMIN_TOKEN with the same value.
