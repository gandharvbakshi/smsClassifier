{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/gandharvbakshi/smsClassifier/main/backend/learning_registry_assets/schemas/corpus-manifest.schema.json",
  "title": "Learning Registry Corpus Manifest",
  "description": "Generated by publish-corpus beside the immutable canonical cases.jsonl object. The safe metadata object recursively rejects raw content, direct identifiers, and private lineage fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "corpusId",
    "metadata",
    "caseCount",
    "casesSha256",
    "casesObject"
  ],
  "properties": {
    "corpusId": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "$ref": "#/$defs/metadataObject"
    },
    "caseCount": {
      "type": "integer",
      "minimum": 0
    },
    "casesSha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "casesObject": {
      "type": "string",
      "minLength": 1,
      "pattern": "(^|/)corpora/[^/]+/cases\\.jsonl$"
    }
  },
  "$defs": {
    "metadataObject": {
      "type": "object",
      "description": "Safe caller-supplied metadata. Forbidden raw-content, direct-identifier, and private-lineage keys are rejected at every nesting depth.",
      "propertyNames": {
        "not": {
          "enum": [
            "sourceFeedbackIds",
            "sourceFeedbackId",
            "sourceFeedbackLineage",
            "sourceFeedbackIdLineage",
            "privateLineage",
            "text",
            "sender",
            "message",
            "body",
            "rawBody",
            "originalText",
            "originalSender",
            "installId",
            "firebaseUid",
            "userNote",
            "deidentifiedText",
            "deidentifiedSender"
          ]
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/metadataValue"
      }
    },
    "metadataValue": {
      "anyOf": [
        {
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ]
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/metadataValue"
          }
        },
        {
          "$ref": "#/$defs/metadataObject"
        }
      ]
    }
  }
}
